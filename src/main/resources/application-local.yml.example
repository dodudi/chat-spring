# 이 파일을 복사해서 application-local.yml 로 이름을 바꾸고 로컬 환경에 맞게 수정하세요.
# application-local.yml 은 .gitignore 대상입니다. 절대 커밋하지 마세요.

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/chat
    username: chat
    password: chat
    driver-class-name: org.postgresql.Driver

  data:
    redis:
      host: localhost
      port: 6379

  jpa:
    hibernate:
      ddl-auto: none
    properties:
      hibernate:
        format_sql: true
    show-sql: true

app:
  jwt:
    local-secret: "local-dev-secret-key-must-be-32-chars!!"

logging:
  level:
    com.chat: DEBUG
    org.springframework.security: DEBUG
    org.springframework.web: DEBUG

management:
  endpoints:
    web:
      exposure:
        include: "*"
  endpoint:
    health:
      show-details: always
